# NestJS API base (same contract as web `NEXT_PUBLIC_API_URL`).
# You may omit the `/api` segment — it is appended automatically to match `app.setGlobalPrefix('api')`.
# Android emulator → host machine: http://10.0.2.2:3000
# iOS simulator → host: http://127.0.0.1:3000
API_BASE_URL=http://10.0.2.2:3000/api

# Optional alias (same value as Next.js); used when API_BASE_URL is empty.
NEXT_PUBLIC_API_URL=

# Optional websocket base URL (without /api). If empty, derived from API_BASE_URL.
WS_BASE_URL=http://10.0.2.2:3000

# Optional alias matching web naming.
NEXT_PUBLIC_WS_URL=

# Optional: used by the backend for LLM features (not sent from the app in production)
SUPABASE_URL=
SUPABASE_ANON_KEY=
OPENAI_API_KEY=

# Offline / demo
MOCK_MODE=false

# Optional: auto-fill login form in dev builds only
DEV_LOGIN_EMAIL=
DEV_LOGIN_PASSWORD=
