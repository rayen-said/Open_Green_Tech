generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



enum Role {
  USER
  ADMIN
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RecommendationType {
  CROP_HEALTH
  IRRIGATION
  FERTILIZER
  BEST_CROP
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  refreshTokenHash String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  devices      Device[]
  alerts       Alert[]
  chatMessages ChatMessage[]
  profile      UserProfile?
  gamification UserGamification?
}

/// Onboarding + field preferences (synced mobile ↔ backend). Used in AI prompts.
model UserProfile {
  userId               String   @id
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  soilType             String?
  crops                Json     @default("[]")
  farmSizeHa           Float?
  lat                  Float?
  lng                  Float?
  habits               Json     @default("{}")
  completedOnboarding  Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// XP / levels / task progress (mobile-first; optional web read later).
model UserGamification {
  userId            String    @id
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp                Int       @default(0)
  level             String    @default("BEGINNER")
  lastDailyCheckIn  DateTime?
  tasksState        Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Device {
  id              String           @id @default(cuid())
  name            String
  location        String
  soilType        String
  cropType        String
  status          DeviceStatus     @default(OFFLINE)
  ownerId         String
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  telemetries     Telemetry[]
  recommendations Recommendation[]
  alerts          Alert[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([ownerId])
}

model Telemetry {
  id          String   @id @default(cuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  temperature Float
  humidity    Float
  light       Float
  anomaly     Boolean  @default(false)
  timestamp   DateTime @default(now())

  @@index([deviceId, timestamp])
}

model Recommendation {
  id          String             @id @default(cuid())
  deviceId    String
  device      Device             @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  type        RecommendationType
  title       String
  explanation String
  reason      String
  detectedIssues Json
  confidence  Int
  createdAt   DateTime           @default(now())

  @@index([deviceId, createdAt])
}

model Alert {
  id           String        @id @default(cuid())
  userId       String?
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  deviceId     String
  device       Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  severity     AlertSeverity
  title        String
  message      String
  acknowledged Boolean       @default(false)
  createdAt    DateTime      @default(now())

  @@index([deviceId, createdAt])
  @@index([userId, createdAt])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
