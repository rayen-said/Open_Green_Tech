PORT=3000
DATABASE_URL=postgresql://postgres:postgres@db:5432/crop_advisor?schema=public
DIRECT_URL=postgresql://postgres:postgres@db:5432/crop_advisor?schema=public
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=info
SUPABASE_JWT_SECRET=
DEMO_API_URL=http://localhost:3000/api
DEMO_EMAIL=admin@agri.com
DEMO_PASSWORD=Admin@12345

# MQTT / HiveMQ
MQTT_ENABLED=true
MQTT_URL=mqtts://your-cluster.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your-username
MQTT_PASSWORD=your-password
MQTT_TLS=true
MQTT_TLS_REJECT_UNAUTHORIZED=true
MQTT_TELEMETRY_TOPIC=greenhouse/+/telemetry
MQTT_ALERTS_TOPIC=greenhouse/+/alerts
MQTT_COMMAND_TOPIC_TEMPLATE=greenhouse/{deviceId}/commands
