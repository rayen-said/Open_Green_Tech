# HiveMQ Cloud settings for Green_house--main scripts and firmware
HIVEMQ_HOST=your-cluster.s1.eu.hivemq.cloud
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=your-username
HIVEMQ_PASSWORD=your-password
GREENHOUSE_DEVICE_ID=esp32-gh-01

# Optional publisher tuning
HIVEMQ_DELAY_SECONDS=2
HIVEMQ_CONNECT_TIMEOUT_SECONDS=15
HIVEMQ_RECONNECT_RETRIES=3
